# Docker Compose settings. Copy this file to .env and replace every secret.
OPENROUTER_API_KEY=
# OpenRouter retires free models often — if AI calls start returning 404,
# update this to a currently-available model id (see openrouter.ai/models).
OPENROUTER_MODEL=openai/gpt-oss-20b:free

POSTGRES_USER=agent
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=agent_invest

ADMIN_PASSWORD=
NEWS_API_KEY=
FRED_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHANNEL_ID=
TELEGRAM_COMMUNITY_CHAT_ID=
TELEGRAM_PAID_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_ADMIN_TOKEN=

# Prefer exact origins. Example: https://agent-invest-frontend.example.com
CORS_ALLOW_ORIGINS=
CORS_ALLOW_ORIGIN_REGEX=
