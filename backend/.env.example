# =============================================================================
#  Agent-Invest — Environment Template
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# =============================================================================

# LLM — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Free default (rate-limited). Reliable paid option: deepseek/deepseek-chat
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Password guarding the /admin model-config page. No default — if blank,
# /admin is fully locked (empty string never matches the login check).
# Set a strong random value in production.
ADMIN_PASSWORD=

# Per-Agent Model Overrides — leave blank to use OPENROUTER_MODEL.
# FAST  : google/gemini-flash-1.5 | meta-llama/llama-3.1-8b-instruct
# SMART : google/gemini-pro-1.5   | mistralai/mistral-large
# BEST  : anthropic/claude-sonnet-4-6 | anthropic/claude-opus-4-8
NEWS_AGENT_MODEL=
SENTIMENT_AGENT_MODEL=
FUNDAMENTAL_AGENT_MODEL=
TECHNICAL_AGENT_MODEL=
SYNTHESIS_AGENT_MODEL=
CRITIC_AGENT_MODEL=

# Database — PostgreSQL
DATABASE_URL=postgresql://agent:secret@localhost:5432/agent_invest
POSTGRES_USER=agent
POSTGRES_PASSWORD=secret
POSTGRES_DB=agent_invest

# News API (optional — https://newsapi.org/register)
NEWS_API_KEY=
# Extra news sources (optional)
ALPHA_VANTAGE_API_KEY=      # https://www.alphavantage.co/support/#api-key (free 25 req/day)
FINNHUB_API_KEY=            # https://finnhub.io (free 60 calls/min)
FRONTEND_URL=http://localhost:3000
# Production: set to your frontend URL, e.g. https://agent-invest-frontend.onrender.com
CORS_ALLOW_ORIGINS=
CORS_ALLOW_ORIGIN_REGEX=https://.*\.(workers|pages)\.dev|https://.*\.onrender\.com
FETCH_INTERVAL_MINUTES=30

# ---------------------------------------------------------------------------
# Telegram Bot
# 1. สร้างบอทใน @BotFather -> ได้ BOT_TOKEN
# 2. ส่ง /start ให้บอท (แชทส่วนตัว)
# 3. เปิด: https://api.telegram.org/bot<TOKEN>/getUpdates
#    หา "chat":{"id": XXXXXXX} -> นั่นคือ chat_id ส่วนตัวของคุณ
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHANNEL_ID=
TELEGRAM_COMMUNITY_CHAT_ID=
TELEGRAM_PAID_CHAT_ID=
# กลุ่มที่ 2 — bot คนละตัว ส่งรายงานรายวันขนานกับ bot1 (ตั้งครบทั้งคู่จึงจะส่ง)
TELEGRAM_BOT2_TOKEN=
TELEGRAM_BOT2_CHANNEL_ID=
# REQUIRED for the bot to work: the /telegram/webhook now fails closed when this
# is blank (a blank secret must not mean "accept any update", or an attacker
# could forge updates with an arbitrary from.id and act as any user). Use a long
# random value; then POST /telegram/webhook/register to push it to Telegram.
TELEGRAM_WEBHOOK_SECRET_TOKEN=
# REQUIRED to use the admin-only Telegram write/preview routes (broadcast,
# webhook register/delete/info, reports/send, reports/preview). Blank = locked.
TELEGRAM_ADMIN_TOKEN=
TELEGRAM_DAILY_REPORT_ENABLED=false
TELEGRAM_COMMUNITY_REPORT_ENABLED=false
TELEGRAM_PAID_REPORT_ENABLED=false
TELEGRAM_DAILY_REPORT_HOUR=8
TELEGRAM_DAILY_REPORT_MINUTE=30
TELEGRAM_TIMEZONE=Asia/Bangkok
TELEGRAM_USE_AI_SUMMARY=true
# private chat: free-text คุยกับ AI (บอทรู้ portfolio/watchlist ของผู้ใช้) — กลุ่มไม่มี AI chat
TELEGRAM_PRIVATE_AI_CHAT=true
TELEGRAM_PUBLIC_NEWS_LIMIT=3
TELEGRAM_PUBLIC_WATCHLIST_LIMIT=3
TELEGRAM_PRIVATE_REPORT_MAX_ASSETS=20
TELEGRAM_PRIVATE_REPORT_MAX_NEWS_ITEMS=20

# Monitor
MONITOR_WATCHLIST_SYMBOLS=AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA,AMD,AVGO,JPM,V,SPY,QQQ,NFLX,COIN,BTC-USD,ETH-USD,SOL-USD,BNB-USD,XRP-USD
MONITOR_ECONOMIC_INDICATORS=FOMC,CPI,PCE,NFP,GDP,PMI,Initial Jobless Claims,Unemployment Rate,Retail Sales,Core Inflation,ECB,BoJ,OPEC
MONITOR_RSS_SOURCES=https://feeds.finance.yahoo.com/rss/2.0/headline,https://www.investing.com/rss/news.rss,https://cointelegraph.com/rss,https://coindesk.com/arc/outboundfeeds/rss/
MONITOR_IPO_WATCHLIST_PATH=../data/ipo_watchlist.json
MONITOR_REPORT_MAX_NEWS_ITEMS=30
MONITOR_REPORT_MAX_WATCHLIST_ASSETS=20

# Economic indicators (FRED). Free key: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
MONITOR_FRED_SERIES=CPI=CPIAUCSL,Core CPI=CPILFESL,PCE=PCEPI,Core PCE=PCEPILFE,Real GDP=GDPC1,Nonfarm Payrolls=PAYEMS,Unemployment Rate=UNRATE,Initial Jobless Claims=ICSA,Retail Sales=RSAFS,Fed Funds Rate=FEDFUNDS,10Y Treasury=DGS10,Yield Curve 10Y-2Y=T10Y2Y,Industrial Production=INDPRO,Consumer Sentiment=UMCSENT,Housing Starts=HOUST
MONITOR_ECONOMIC_REPORT_LIMIT=15

# Advance calendar alerts
CALENDAR_ALERT_ENABLED=true
CALENDAR_ALERT_DAYS_AHEAD=3
CALENDAR_REPORT_DAYS_AHEAD=14

# ---------------------------------------------------------------------------
# RAG + Embeddings (Phase 3)
# OpenRouter ไม่รองรับ /embeddings — ต้องใช้ provider แยก
#
# ตัวเลือก A: Jina AI FREE (1M tokens/เดือน, ไม่ต้องบัตรเครดิต)
#   -> https://jina.ai/?sui=apikey  |  EMBEDDING_DIM=768
# ตัวเลือก B: OpenAI direct
#   EMBEDDING_BASE_URL=https://api.openai.com/v1
#   EMBEDDING_MODEL=text-embedding-3-small  |  EMBEDDING_DIM=1536
# ---------------------------------------------------------------------------
RAG_ENABLED=true
RAG_TOP_K=5
RAG_MIN_SCORE=0.0
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.jina.ai/v1
EMBEDDING_MODEL=jina-embeddings-v2-base-en
EMBEDDING_DIM=768
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Dataset collection (Phase 4)
AUTO_ANALYZE_ENABLED=false
AUTO_ANALYZE_SYMBOLS=AAPL,MSFT,NVDA,TSLA,SPY,QQQ,BTC-USD,ETH-USD
AUTO_ANALYZE_TIMEFRAME=1w
AUTO_ANALYZE_INTERVAL_HOURS=24

# Local fine-tuned model (Phase 5)
USE_LOCAL_MODEL=false
LOCAL_MODEL_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=agent-invest-7b
