# =============================================================================
#  Agent-Invest — Environment Template
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# =============================================================================

# LLM — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Per-Agent Model Overrides (ถ้าว่าง = ใช้ OPENROUTER_MODEL)
# FAST  : google/gemini-flash-1.5 | meta-llama/llama-3.1-8b-instruct
# SMART : google/gemini-pro-1.5   | mistralai/mistral-large
# BEST  : anthropic/claude-sonnet-4-6 | anthropic/claude-opus-4-8
NEWS_AGENT_MODEL=
SENTIMENT_AGENT_MODEL=
FUNDAMENTAL_AGENT_MODEL=
TECHNICAL_AGENT_MODEL=
SYNTHESIS_AGENT_MODEL=
CRITIC_AGENT_MODEL=

# Database — PostgreSQL
DATABASE_URL=postgresql://agent:secret@localhost:5432/agent_invest
POSTGRES_USER=agent
POSTGRES_PASSWORD=secret
POSTGRES_DB=agent_invest

# News API (optional — https://newsapi.org/register)
NEWS_API_KEY=
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Telegram Bot
# 1. สร้างบอทใน @BotFather -> ได้ BOT_TOKEN
# 2. ส่ง /start ให้บอท (แชทส่วนตัว)
# 3. เปิด: https://api.telegram.org/bot<TOKEN>/getUpdates
#    หา "chat":{"id": XXXXXXX} -> นั่นคือ chat_id ส่วนตัวของคุณ
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHANNEL_ID=
TELEGRAM_COMMUNITY_CHAT_ID=
TELEGRAM_PAID_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_ADMIN_TOKEN=
TELEGRAM_DAILY_REPORT_ENABLED=false
TELEGRAM_COMMUNITY_REPORT_ENABLED=false
TELEGRAM_PAID_REPORT_ENABLED=false
TELEGRAM_DAILY_REPORT_HOUR=8
TELEGRAM_DAILY_REPORT_MINUTE=30
TELEGRAM_TIMEZONE=Asia/Bangkok
TELEGRAM_USE_AI_SUMMARY=true
TELEGRAM_PUBLIC_NEWS_LIMIT=3
TELEGRAM_PUBLIC_WATCHLIST_LIMIT=3
TELEGRAM_PRIVATE_REPORT_MAX_ASSETS=8
TELEGRAM_PRIVATE_REPORT_MAX_NEWS_ITEMS=20

# Monitor
MONITOR_WATCHLIST_SYMBOLS=AAPL,MSFT,NVDA,TSLA,SPY,QQQ,BTC-USD,ETH-USD
MONITOR_ECONOMIC_INDICATORS=FOMC,CPI,PCE,NFP,GDP,PMI,Initial Jobless Claims,Unemployment Rate,Retail Sales,Core Inflation,ECB,BoJ,OPEC
MONITOR_RSS_SOURCES=https://feeds.finance.yahoo.com/rss/2.0/headline,https://www.investing.com/rss/news.rss,https://cointelegraph.com/rss,https://coindesk.com/arc/outboundfeeds/rss/
MONITOR_IPO_WATCHLIST_PATH=../data/ipo_watchlist.json
MONITOR_REPORT_MAX_NEWS_ITEMS=30
MONITOR_REPORT_MAX_WATCHLIST_ASSETS=20

# ---------------------------------------------------------------------------
# RAG + Embeddings (Phase 3)
# OpenRouter ไม่รองรับ /embeddings — ต้องใช้ provider แยก
#
# ตัวเลือก A: Jina AI FREE (1M tokens/เดือน, ไม่ต้องบัตรเครดิต)
#   -> https://jina.ai/?sui=apikey
#   EMBEDDING_DIM=768
#
# ตัวเลือก B: OpenAI direct
#   EMBEDDING_API_KEY=sk-...
#   EMBEDDING_BASE_URL=https://api.openai.com/v1
#   EMBEDDING_MODEL=text-embedding-3-small
#   EMBEDDING_DIM=1536
# ---------------------------------------------------------------------------
RAG_ENABLED=true
RAG_TOP_K=5
RAG_MIN_SCORE=0.0
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.jina.ai/v1
EMBEDDING_MODEL=jina-embeddings-v2-base-en
EMBEDDING_DIM=768

# Dataset collection (Phase 4)
AUTO_ANALYZE_ENABLED=false
AUTO_ANALYZE_SYMBOLS=AAPL,MSFT,NVDA,TSLA,SPY,QQQ,BTC-USD,ETH-USD
AUTO_ANALYZE_TIMEFRAME=1w
AUTO_ANALYZE_INTERVAL_HOURS=24

# Local fine-tuned model (Phase 5)
USE_LOCAL_MODEL=false
LOCAL_MODEL_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=agent-invest-7b
