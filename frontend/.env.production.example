# Render MVP uses BACKEND_URL from render.yaml and keeps browser calls on /api.
# Do not set NEXT_PUBLIC_API_URL for the Render frontend unless you want the browser
# to call the backend directly and handle CORS yourself.

# Cloudflare/static-only deploys can uncomment this before build:
# NEXT_PUBLIC_API_URL=https://agent-invest-backend.onrender.com
